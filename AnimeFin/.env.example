FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=0

# Local run defaults; Docker Compose overrides these for the flask-app service.
DOWNLOADS_DIR=./downloads
DATABASE_PATH=./data/jobs.sqlite3
ANI_CLI_PATH=./ani-cli/ani-cli
# Optional: path or executable name for animepahe-dl (defaults to PATH lookup)
# ANIMEPAHE_DL=animepahe-dl
# animepahe-dl reads ~/.config/animepahe-dl/config.json under this synthetic HOME (persist on Docker by pointing at /data/...)
# ANIMEPAHE_DL_HOME=./data/animepahe-runtime
# Default base_url written only when config.json is missing (first run)
# ANIMEPAHE_BASE_URL=https://animepahe.com

ALLANIME_API=https://api.allanime.day/api
ALLANIME_REFERER=https://allmanga.to
